.symphony/
silver-agent-workspaces/
log/
*.log

# Generated reports. Keep directories and docs, not run output.
reports/**/*.md
!reports/**/README.md
!reports/**/.gitkeep

# Build artifacts
dist/
build/
*.egg-info/
